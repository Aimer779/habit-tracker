<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Habit" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Minimal base to allow DayNight automatic switching -->
    </style>

    <style name="Theme.Habit" parent="Base.Theme.Habit" />

    <style name="Theme.Habit.Mint" parent="Base.Theme.Habit">
        <item name="colorPrimary">@color/mint_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/mint_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/mint_primary</item>
        <item name="colorSecondary">@color/mint_primary</item>
        <item name="android:statusBarColor">@color/mint_primary</item>
        <item name="android:navigationBarColor">@color/mint_primary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

